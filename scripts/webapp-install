#!/bin/bash
# webapp-install NAME URL [ICON_URL_OR_PATH]

set -euo pipefail

readonly APP_DIR="$HOME/.local/share/applications"
readonly ICON_DIR="$HOME/.local/share/applications/icons"
readonly PROFILE_DIR="$HOME/.local/share/webapps/profiles"

mkdir -p "$APP_DIR" "$ICON_DIR" "$PROFILE_DIR"

die()  { printf '\e[31merror:\e[0m %s\n' "$*" >&2; exit 1; }
info() { printf '\e[32m::\e[0m %s\n' "$*"; }

(( $# >= 2 )) || die "usage: webapp-install NAME URL [ICON_URL_OR_PATH]"

APP_NAME="$1"
APP_URL="$2"
ICON_REF="${3:-}"

[[ "$APP_URL" =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]] || APP_URL="https://$APP_URL"

SLUG=$(printf '%s' "$APP_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]\+/-/g; s/^-\+//; s/-\+$//')
[[ -n "$SLUG" ]] || die "name produced empty slug"

DESKTOP_FILE="$APP_DIR/webapp-$SLUG.desktop"
ICON_PATH="$ICON_DIR/$SLUG.png"
APP_PROFILE="$PROFILE_DIR/$SLUG"

# Chromium auto-generates WM_CLASS for --app= windows as:
#   chrome-<host-and-path-with-slashes-as-dots>__-Default
predict_wm_class() {
  local stripped
  stripped=$(printf '%s' "$1" | sed -E 's#^https?://##; s#/$##; s#/#.#g')
  printf 'chrome-%s__-Default' "$stripped"
}
WM_CLASS=$(predict_wm_class "$APP_URL")

fetch_icon() {
  curl -fsSL --max-time 10 -A "Mozilla/5.0" -o "$2" "$1" 2>/dev/null && [[ -s "$2" ]]
}

get_page_icons() {
  local base
  base=$(printf '%s' "$1" | sed -E 's#^(https?://[^/]+).*#\1#')
  curl -fsSL --max-time 10 -A "Mozilla/5.0" "$1" 2>/dev/null \
    | tr '\n' ' ' \
    | grep -oiE '<link[^>]+rel=["'\''][^"'\'']*icon[^"'\'']*["'\''][^>]*>' \
    | grep -oiE 'href=["'\''][^"'\'']+["'\'']' \
    | sed -E 's/href=["'\'']([^"'\'']+)["'\'']/\1/i' \
    | while read -r href; do
        case "$href" in
          http://*|https://*) printf '%s\n' "$href" ;;
          //*)                printf 'https:%s\n' "$href" ;;
          /*)                 printf '%s%s\n' "$base" "$href" ;;
          *)                  printf '%s/%s\n' "$base" "$href" ;;
        esac
      done
}

convert_icon() {
  # [-1] picks the highest-res frame from multi-frame ICO files
  convert "$1[-1]" "$2" 2>/dev/null || convert "$1" "$2"
}

install_icon() {
  local tmp
  tmp=$(mktemp --suffix=.icon)

  if [[ -n "$ICON_REF" ]]; then
    if [[ -f "$ICON_REF" ]]; then
      cp "$ICON_REF" "$tmp"
    elif [[ "$ICON_REF" =~ ^https?:// ]]; then
      fetch_icon "$ICON_REF" "$tmp" || { rm -f "$tmp"; die "could not fetch icon from $ICON_REF"; }
    else
      rm -f "$tmp"; die "icon ref must be a file path or http(s) URL"
    fi
    convert_icon "$tmp" "$ICON_PATH"; info "icon: user-provided"; return 0
  fi

  info "scraping page for icons..."
  local candidate
  while read -r candidate; do
    [[ -z "$candidate" ]] && continue
    if fetch_icon "$candidate" "$tmp"; then
      convert_icon "$tmp" "$ICON_PATH"; info "icon: found in page ($candidate)"; return 0
    fi
  done < <(get_page_icons "$APP_URL")

  local base
  base=$(printf '%s' "$APP_URL" | sed -E 's#^(https?://[^/]+).*#\1#')
  if fetch_icon "$base/favicon.ico" "$tmp"; then
    convert_icon "$tmp" "$ICON_PATH"; info "icon: /favicon.ico"; return 0
  fi

  if fetch_icon "https://www.google.com/s2/favicons?domain=${APP_URL}&sz=256" "$tmp"; then
    mv "$tmp" "$ICON_PATH"; info "icon: google favicon service (fallback, 256px max)"; return 0
  fi

  rm -f "$tmp"
  die "could not obtain icon from any source — pass one explicitly as 3rd arg"
}

install_icon

cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=$APP_NAME
Comment=$APP_NAME (web app)
Exec=/usr/bin/chromium --app=$APP_URL --user-data-dir=$APP_PROFILE --ozone-platform=x11 --no-first-run --no-default-browser-check
Icon=$ICON_PATH
Terminal=false
StartupNotify=true
StartupWMClass=$WM_CLASS
Categories=Network;WebBrowser;
EOF

chmod +x "$DESKTOP_FILE"

command -v update-desktop-database >/dev/null && \
  update-desktop-database "$APP_DIR" >/dev/null 2>&1 || true

WM_CLASS_REGEX=$(printf '%s' "$WM_CLASS" | sed 's/\./\\./g')

cat <<EOF

$(printf '\e[32m✓ installed\e[0m') $APP_NAME

  desktop:  $DESKTOP_FILE
  icon:     $ICON_PATH
  profile:  $APP_PROFILE
  class:    $WM_CLASS

Hyprland windowrule:
  windowrule = float, class:^($WM_CLASS_REGEX)\$
EOF
